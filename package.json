{
  "name": "weather-station-card",
  "version": "1.13.0",
  "description": "Lovelace card showing past weather-station measurements with the weather-chart-card layout, plus live current-condition rendering driven by sensor history.",
  "keywords": [
    "home-assistant",
    "homeassistant",
    "hass",
    "lovelace",
    "custom-cards",
    "weather",
    "weather-station",
    "sensor",
    "history",
    "statistics",
    "chart"
  ],
  "main": "dist/weather-station-card.js",
  "module": "src/main.ts",
  "homepage": "https://github.com/chriguschneider/weather-station-card",
  "bugs": {
    "url": "https://github.com/chriguschneider/weather-station-card/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/chriguschneider/weather-station-card.git"
  },
  "author": "chrigu",
  "contributors": [
    "Marc Lamberts (original weather-chart-card author)"
  ],
  "license": "MIT",
  "dependencies": {
    "lit": "^3.3.3",
    "uplot": "^1.6.32"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@vitest/coverage-v8": "^4.1.5",
    "cross-env": "^10.1.0",
    "dependency-cruiser": "^17.4.0",
    "eslint": "^10.3.0",
    "eslint-plugin-lit": "^2.2.1",
    "eslint-plugin-sonarjs": "^4.0.3",
    "globals": "^17.6.0",
    "http-server": "^14.1.1",
    "jsdom": "^29.1.1",
    "rollup": "^4.9.6",
    "rollup-plugin-copy": "^3.5.0",
    "rollup-plugin-node-resolve": "^5.2.0",
    "rollup-plugin-serve": "^3.0.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.1.5"
  },
  "scripts": {
    "start": "rollup -c rollup.config.dev.js --watch",
    "build": "npm run lint && npm run typecheck && npm run test && npm run rollup",
    "lint": "eslint src tests-e2e",
    "depcheck": "depcruise src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "rollup": "rollup -c",
    "bundle:analyze": "cross-env BUNDLE_ANALYZE=1 rollup -c",
    "perf:diagnose": "cross-env PERF_DIAGNOSE=1 playwright test tests-e2e/perf-diagnose.spec.ts",
    "test:e2e": "playwright test",
    "test:e2e:update": "playwright test --update-snapshots"
  }
}
